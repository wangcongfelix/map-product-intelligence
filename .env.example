# Default analysis provider. Use "mock" for local safety, or "deepseek" after configuring a key.
AI_PROVIDER=mock

# Server-only DeepSeek configuration. Do not expose this value in client code.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ANALYSIS_PROMPT_VERSION=v1

# Optional public application URL for deployment callbacks and generated links.
NEXT_PUBLIC_APP_URL=
